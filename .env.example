# Local development settings.
# This file intentionally contains no secrets.

PING_ENV=development
PING_HOST=0.0.0.0
PING_PORT=8000
PING_DATABASE_PATH=data/dev-check.sqlite3

# Admin dashboard auth.
# Replace these values in a local .env file; do not commit real secrets.
PING_ADMIN_USERNAME=admin
PING_ADMIN_PASSWORD_HASH=pbkdf2_sha256$replace-with-salt$replace-with-password-hash
PING_ADMIN_SESSION_SECRET=replace-with-random-session-secret
PING_COOKIE_SECURE=false
